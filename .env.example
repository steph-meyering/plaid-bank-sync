PLAID_CLIENT_ID=your_client_id
PLAID_ENV=sandbox

# Per-environment secrets (the one matching PLAID_ENV is used)
PLAID_SECRET_SANDBOX=your_sandbox_secret
PLAID_SECRET_PRODUCTION=your_production_secret

DATABASE_URL=sqlite+aiosqlite:///./plaid_data.db
SYNC_INTERVAL_HOURS=6
LOG_LEVEL=INFO
PLAID_REDIRECT_URI=
